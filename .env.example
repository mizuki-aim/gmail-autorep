# Server Configuration
PORT=3000
NODE_ENV=development

# Google Pub/Sub Configuration
# Token used to authenticate incoming Pub/Sub push messages
PUBSUB_AUTH_TOKEN=your-pubsub-auth-token

# Gmail API Configuration
# OAuth2 credentials for Gmail API access
# Note: Scopes should NOT include gmail.send - draft only
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_USER_EMAIL=your-email@example.com

# LLM Configuration (Anthropic Claude)
LLM_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_MS=30000

# Discord Configuration
# Webhook URL for Discord notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Client Allowlist (comma-separated domains)
# Emails from these domains will be automatically marked as High priority
CLIENT_ALLOWLIST=client1.com,client2.co.jp

# Storage Configuration
STORAGE_TYPE=file
STORAGE_FILE_PATH=./data/processed-ids.json

# Logging
LOG_LEVEL=debug
